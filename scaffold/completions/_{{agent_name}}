#compdef {{agent_name}}

local -a commands
commands=(
  'fd-new:create a feature design'
  'fd-new-prompt:render a feature design creation prompt'
  'fd-close:archive a feature design'
  'fd-status:show feature design status'
  'fd-work-prompt:render a worker prompt for a design sub-item'
  'worker:launch a provider-aware worker'
  'worktree:create a worktree'
  'sync-branch:rebase a worktree branch'
  'ship:run the shipping workflow'
  'ship-prompt:render a shipping workflow prompt'
  'session-review:review the current session'
  'session-review-prompt:render a session review prompt'
  'completion:print shell completion scripts'
)

local -a common_design_flags
common_design_flags=(
  '--effort[Set design effort]:effort:(small medium large)'
  '--priority[Set design priority]:priority:(low medium high critical)'
  '--repo[Set repo hint]:repo: '
  '--provider-hint[Set provider hint]:provider:(claude codex)'
  '--profile-hint[Set profile hint]:profile:(fast strong)'
  '--branch-suffix[Set branch suffix]:suffix: '
  '--verification-command[Set verification command]:command: '
  '--dry-run[Preview the command only]'
)

_arguments -C \
  '1:command:->command' \
  '*::arg:->args'

case $state in
  command)
    _describe -t commands '{{agent_name}} commands' commands
    ;;
  args)
    case $words[2] in
      completion)
        _values 'shell' bash zsh
        ;;
      fd-new|fd-new-prompt)
        _arguments $common_design_flags
        ;;
      fd-close)
        _arguments \
          '--force[Archive even if incomplete]' \
          '--dry-run[Preview the command only]'
        ;;
      fd-work-prompt)
        _arguments \
          '--base[Override the base branch]:branch: '
        ;;
      worker)
        _arguments \
          '--provider[Choose worker provider]:provider:(claude codex)' \
          '--profile[Choose worker profile]:profile:(fast strong)' \
          '--model[Override provider model]:model: ' \
          '--base[Override the base branch]:branch: ' \
          '--dry-run[Preview the command only]'
        ;;
      worktree)
        _arguments \
          '--base[Override the base branch]:branch: ' \
          '--dry-run[Preview the command only]'
        ;;
      sync-branch)
        _arguments \
          '--base[Override the base branch]:branch: ' \
          '--dry-run[Preview the command only]'
        ;;
      ship|ship-prompt)
        _arguments \
          '--base[Override the base branch]:branch: ' \
          '--tier[Verification tier]:tier:(1 2)' \
          '--quick[Use quick verification mode]' \
          '--skip-verify[Skip verification]' \
          '--push[Push the branch to origin]' \
          '--create-pr[Create a pull request]' \
          '--title[Override PR title]:title: ' \
          '--body-file[Read PR body from a file]:path:_files' \
          '--dry-run[Preview the command only]'
        ;;
      session-review|session-review-prompt)
        _arguments \
          '--run-session-end[Run the session end checklist]' \
          '--dry-run[Preview the command only]'
        ;;
    esac
    ;;
esac
